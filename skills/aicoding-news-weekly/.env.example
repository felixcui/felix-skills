# ============================================
# AICoding 资讯周报 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 注意：.env 文件已加入 .gitignore，不会提交到仓库

# --------------------------------------------
# 飞书 API 凭证（必填）
# --------------------------------------------
# 用于调用飞书多维表格 API 获取资讯数据
# 获取方式：https://open.feishu.cn/app → 创建应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# --------------------------------------------
# 微信公众号 API 凭证（可选，仅 --weixin 模式需要）
# --------------------------------------------
# 用于通过 API 创建公众号草稿
# 获取方式：https://mp.weixin.qq.com/ → 开发 → 基本配置
# 注意：需要认证的服务号，并在公众号后台设置服务器 IP 白名单
WECHAT_APPID=
WECHAT_APPSECRET=
